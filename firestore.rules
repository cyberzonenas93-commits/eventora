rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOrgOwner(organizationId) {
      return isSignedIn()
        && organizationId is string
        && organizationId == 'org_' + request.auth.uid;
    }

    function isOrgMember(organizationId) {
      return isSignedIn()
        && organizationId is string
        && exists(
          /databases/$(database)/documents/organization_members/$(organizationId + '_' + request.auth.uid)
        )
        && get(
          /databases/$(database)/documents/organization_members/$(organizationId + '_' + request.auth.uid)
        ).data.status == 'active';
    }

    function isEventManager(organizationId) {
      return isAdmin() || isOrgOwner(organizationId) || isOrgMember(organizationId);
    }

    function canWriteOwnOrganizerApplication(applicationId) {
      return isSignedIn()
        && request.auth.uid == applicationId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['draft', 'submitted'];
    }

    function validOwnUserProfile(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        // Prevent clients from escalating their own privileges
        && !request.resource.data.keys().hasAny(['roles', 'adminRole'])
        // Display name must be a non-empty string if provided
        && (
          !request.resource.data.keys().hasAny(['displayName'])
          || (request.resource.data.displayName is string && request.resource.data.displayName.size() > 0)
        )
        && (
          !request.resource.data.keys().hasAny(['organizerApplicationStatus'])
          || request.resource.data.organizerApplicationStatus in ['notStarted', 'draft', 'submitted']
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if validOwnUserProfile(userId);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
    }

    match /organizer_applications/{applicationId} {
      allow read: if isSignedIn() && (request.auth.uid == applicationId || isAdmin());
      allow create: if canWriteOwnOrganizerApplication(applicationId);
      allow update: if canWriteOwnOrganizerApplication(applicationId)
        && (!resource.data.keys().hasAny(['organizationId']) || request.resource.data.organizationId == resource.data.organizationId);
    }

    match /organizations/{organizationId} {
      allow read: if isEventManager(organizationId);
      allow create, update: if isEventManager(organizationId);
    }

    match /organization_members/{membershipId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || isAdmin()
          || isOrgMember(resource.data.organizationId)
        );
      allow create, update: if isAdmin() || isOrgMember(request.resource.data.organizationId);
    }

    match /events/{eventId} {
      allow read: if resource.data.visibility == 'public'
        || isEventManager(resource.data.organizationId);
      allow create: if isEventManager(request.resource.data.organizationId);
      allow update: if isEventManager(resource.data.organizationId)
        || isEventManager(request.resource.data.organizationId);
    }

    match /event_occurrences/{occurrenceId} {
      allow read: if resource.data.visibility == 'public'
        || isEventManager(resource.data.organizationId);
      allow create, update: if isEventManager(request.resource.data.organizationId)
        || isEventManager(resource.data.organizationId);
    }

    match /event_rsvps/{rsvpId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || isEventManager(resource.data.organizationId)
        );
      allow create, update: if isSignedIn()
        && (
          request.resource.data.userId == request.auth.uid
          || isEventManager(request.resource.data.organizationId)
        );
    }

    match /event_ticket_orders/{orderId} {
      allow read: if (isSignedIn() && (
          request.auth.uid == resource.data.buyerId
          || isEventManager(resource.data.organizationId)
        ))
        // Web checkout orders are readable by anyone who knows the orderId —
        // the orderId is a random Firestore ID only returned to the buyer's browser
        // via the Hubtel post-payment redirect URL, so it is effectively a secret.
        || resource.data.source == 'web';
      allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isEventManager(resource.data.organizationId)
        || isEventManager(request.resource.data.organizationId);
    }

    match /event_ticket_lookups/{lookupId} {
      allow read, update: if isEventManager(resource.data.organizationId)
        || isEventManager(request.resource.data.organizationId);
      allow create: if isEventManager(request.resource.data.organizationId);
    }

    match /event_reminders/{reminderId} {
      allow read, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create, update: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
    }

    match /event_reports/{reportId} {
      allow create: if request.resource.data.keys().hasAll(['eventId', 'eventTitle', 'reason', 'details', 'createdAt'])
        && request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && request.resource.data.eventTitle is string
        && request.resource.data.eventTitle.size() > 0
        && request.resource.data.eventTitle.size() <= 500
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 3
        && request.resource.data.reason.size() <= 500
        && request.resource.data.details is string
        && request.resource.data.details.size() >= 10
        && request.resource.data.details.size() <= 4000
        // Prevent clients from writing arbitrary extra fields
        && request.resource.data.keys().hasOnly(['eventId', 'eventTitle', 'reason', 'details', 'createdAt']);
      allow read: if isAdmin();
    }

    match /payout_requests/{requestId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /share_links/{shareLinkId} {
      allow read: if resource.data.status == 'active'
        || isEventManager(resource.data.organizationId);
      allow create, update: if isEventManager(request.resource.data.organizationId)
        || isEventManager(resource.data.organizationId);
    }

    match /promotion_campaigns/{campaignId} {
      allow read: if isEventManager(resource.data.organizationId);
      allow create, update: if isEventManager(request.resource.data.organizationId)
        || isEventManager(resource.data.organizationId);
    }

    match /notification_jobs/{jobId} {
      allow read: if isAdmin();
    }

    match /push_queue/{queueId} {
      allow read: if isAdmin();
    }

    match /advertiser_wallets/{walletId} {
      allow read: if isOrgOwner(walletId);
      allow create, update, delete: if false;
    }

    match /wallet_transactions/{transactionId} {
      allow read: if isSignedIn()
        && resource.data.walletId == 'org_' + request.auth.uid;
      allow create, update, delete: if false;
    }

    match /sms_opt_out/{phone} {
      allow read, write: if false;
    }

    match /promo_packages/{packageId} {
      allow read, write: if false;
    }
  }
}
