rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        // A revoked admin is marked status:'disabled' rather than deleted; such
        // a doc must not retain client access (matches the Cloud Functions check).
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status != 'disabled';
    }

    function isOrgOwner(organizationId) {
      return isSignedIn()
        && organizationId is string
        && organizationId == 'org_' + request.auth.uid;
    }

    function isOrgMember(organizationId) {
      return isSignedIn()
        && organizationId is string
        && exists(
          /databases/$(database)/documents/organization_members/$(organizationId + '_' + request.auth.uid)
        )
        && get(
          /databases/$(database)/documents/organization_members/$(organizationId + '_' + request.auth.uid)
        ).data.status == 'active';
    }

    function ownsOrganizerApplication(organizationId) {
      return isSignedIn()
        && organizationId is string
        // An applicant may only ever manage their OWN org (org_<uid>). Without
        // this, a self-authored application claiming a victim org would grant
        // event-manager rights over it (privilege escalation); enforcing it on
        // the read side also neutralizes any malicious doc written previously.
        && organizationId == 'org_' + request.auth.uid
        && exists(/databases/$(database)/documents/organizer_applications/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizer_applications/$(request.auth.uid)).data.organizationId == organizationId;
    }

    function isEventManager(organizationId) {
      return isAdmin() || isOrgOwner(organizationId) || isOrgMember(organizationId) || ownsOrganizerApplication(organizationId);
    }

    function organizationBillingFields() {
      return ['billing', 'billingPlanId', 'planId', 'subscription', 'entitlements'];
    }

    function validPlaceSubscription(subscriptionId) {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.placeId is string
        && request.resource.data.placeId.size() > 0
        && subscriptionId == request.auth.uid + '_' + request.resource.data.placeId
        && exists(/databases/$(database)/documents/places/$(request.resource.data.placeId))
        && request.resource.data.status in ['active', 'unsubscribed']
        && (!request.resource.data.keys().hasAny(['channels'])
          || (
            request.resource.data.channels is list
            && request.resource.data.channels.hasOnly([
              'events',
              'menu_specials',
              'reservation_alerts',
              'announcements',
            ])
          ))
        && (!request.resource.data.keys().hasAny(['email'])
          || request.resource.data.email == request.auth.token.email)
        && request.resource.data.keys().hasOnly([
          'placeId',
          'userId',
          'userName',
          'phone',
          'email',
          'channels',
          'prefs',
          'status',
          'createdAt',
          'updatedAt',
        ]);
    }

    function canWriteOwnOrganizerApplication(applicationId) {
      return isSignedIn()
        && request.auth.uid == applicationId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['draft', 'submitted']
        // A client may only claim their own org id, never a victim org.
        && (
          !request.resource.data.keys().hasAny(['organizationId'])
          || request.resource.data.organizationId == 'org_' + request.auth.uid
        );
    }

    function validOwnUserProfile(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        // Prevent clients from escalating their own privileges
        && !request.resource.data.keys().hasAny(['roles', 'adminRole'])
        // Display name must be a non-empty string if provided
        && (
          !request.resource.data.keys().hasAny(['displayName'])
          || (request.resource.data.displayName is string && request.resource.data.displayName.size() > 0)
        )
        && (
          !request.resource.data.keys().hasAny(['organizerApplicationStatus'])
          || request.resource.data.organizerApplicationStatus in ['notStarted', 'draft', 'submitted']
        );
    }

    function validOwnUserProfileUpdate(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        // Existing role fields may remain on the document, but clients may not
        // change them through ordinary profile updates.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'adminRole'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName'])
          || (request.resource.data.displayName is string && request.resource.data.displayName.size() > 0)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['organizerApplicationStatus'])
          || request.resource.data.organizerApplicationStatus in ['notStarted', 'draft', 'submitted']
        );
    }

    function validBuyerPaymentFailureUpdate() {
      return isSignedIn()
        && request.auth.uid == resource.data.buyerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'paymentStatus',
          'paymentError',
          'updatedAt',
        ])
        && request.resource.data.paymentStatus == 'failed';
    }

    // Clients may create their own pending ticket order, but may NEVER set the
    // server-controlled settlement/issuance fields or self-declare a paid state.
    // Payment confirmation, ticket issuance and admission all happen server-side
    // (admin SDK bypasses rules). This is what makes the server-only
    // `settlementEligible` flag — the basis for organizer payouts — unforgeable.
    function validBuyerTicketOrderCreate() {
      return isSignedIn()
        && request.resource.data.buyerId == request.auth.uid
        && (!request.resource.data.keys().hasAny(['status'])
          || request.resource.data.status in ['pending', 'initiated'])
        && (!request.resource.data.keys().hasAny(['paymentStatus'])
          || request.resource.data.paymentStatus in ['pending', 'initiated', 'cash_at_gate', 'cashAtGate'])
        // The server-only settlement flag (the basis for organizer payouts) can
        // NEVER be set by a client — this is what makes the payout balance
        // unforgeable even though clients may still create their own orders.
        && !request.resource.data.keys().hasAny([
          'settlementEligible',
          'tickets',
          'paidAt',
          'paymentConfirmedAt',
          'callbackReceivedAt',
          'hubtelCallbackPayload',
          'admittedAt',
          'admittedBy',
        ]);
    }

    function validSupportTicketCreate() {
      return isSignedIn()
        && request.resource.data.keys().hasOnly([
          'userId',
          'createdBy',
          'name',
          'email',
          'phone',
          'topic',
          'subject',
          'status',
          'priority',
          'source',
          'latestMessage',
          'adminUnreadCount',
          'userUnreadCount',
          'createdAt',
          'updatedAt',
          'lastMessageAt',
          'lastCustomerMessageAt',
        ])
        && request.resource.data.keys().hasAll([
          'userId',
          'createdBy',
          'name',
          'email',
          'topic',
          'subject',
          'status',
          'priority',
          'source',
          'latestMessage',
          'adminUnreadCount',
          'userUnreadCount',
          'createdAt',
          'updatedAt',
          'lastMessageAt',
          'lastCustomerMessageAt',
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 160
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 240
        && (!request.resource.data.keys().hasAny(['phone'])
          || (request.resource.data.phone is string && request.resource.data.phone.size() <= 80))
        && request.resource.data.topic is string
        && request.resource.data.topic.size() >= 2
        && request.resource.data.topic.size() <= 120
        && request.resource.data.subject is string
        && request.resource.data.subject.size() >= 2
        && request.resource.data.subject.size() <= 240
        && request.resource.data.latestMessage is string
        && request.resource.data.latestMessage.size() >= 10
        && request.resource.data.latestMessage.size() <= 4000
        && request.resource.data.status == 'open'
        && request.resource.data.priority in ['normal', 'high', 'urgent']
        && request.resource.data.source in ['mobile_app', 'web_app']
        && request.resource.data.adminUnreadCount == 0
        && request.resource.data.userUnreadCount == 0;
    }

    function ownsSupportTicket(ticketId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/support_tickets/$(ticketId))
        && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid;
    }

    function validOwnSupportTicketUpdate() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'userUnreadCount',
          'lastUserReadAt',
          'updatedAt',
        ])
        && request.resource.data.userUnreadCount == 0;
    }

    function validSupportMessageBody() {
      return request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 4000
        && (!request.resource.data.keys().hasAny(['senderName'])
          || (request.resource.data.senderName is string && request.resource.data.senderName.size() <= 160));
    }

    function validUserSupportMessageCreate(ticketId) {
      return ownsSupportTicket(ticketId)
        && request.resource.data.keys().hasOnly([
          'senderType',
          'senderId',
          'senderName',
          'body',
          'createdAt',
        ])
        && request.resource.data.senderType == 'user'
        && request.resource.data.senderId == request.auth.uid
        && validSupportMessageBody();
    }

    function validAdminSupportMessageCreate() {
      return isAdmin()
        && request.resource.data.keys().hasOnly([
          'senderType',
          'senderId',
          'senderName',
          'body',
          'createdAt',
        ])
        && request.resource.data.senderType == 'admin'
        && request.resource.data.senderId == request.auth.uid
        && validSupportMessageBody();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if validOwnUserProfile(userId);
      allow update: if validOwnUserProfileUpdate(userId);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
    }

    match /organizer_applications/{applicationId} {
      allow read: if isSignedIn() && (request.auth.uid == applicationId || isAdmin());
      allow create: if canWriteOwnOrganizerApplication(applicationId);
      allow update: if canWriteOwnOrganizerApplication(applicationId)
        && (!resource.data.keys().hasAny(['organizationId']) || request.resource.data.organizationId == resource.data.organizationId);
    }

    match /organizations/{organizationId} {
      allow read: if isEventManager(organizationId);
      allow create: if isEventManager(organizationId)
        && (isAdmin() || !request.resource.data.keys().hasAny(organizationBillingFields()));
      allow update: if isEventManager(organizationId)
        && (
          isAdmin()
          || !request.resource.data.diff(resource.data).affectedKeys().hasAny(organizationBillingFields())
        );
    }

    match /organization_members/{membershipId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || isAdmin()
          || isOrgMember(resource.data.organizationId)
        );
      allow create, update: if isAdmin() || isOrgMember(request.resource.data.organizationId);
    }

    match /events/{eventId} {
      allow read: if resource.data.visibility == 'public'
        || isEventManager(resource.data.organizationId);
      allow create: if isEventManager(request.resource.data.organizationId);
      // Only the current owner may update, and ownership cannot be reassigned —
      // prevents hijacking an event by repointing organizationId at your own org.
      allow update: if isEventManager(resource.data.organizationId)
        && request.resource.data.organizationId == resource.data.organizationId;
    }

    match /event_occurrences/{occurrenceId} {
      allow read: if resource.data.visibility == 'public'
        || isEventManager(resource.data.organizationId);
      allow create: if isEventManager(request.resource.data.organizationId);
      allow update: if isEventManager(resource.data.organizationId)
        && request.resource.data.organizationId == resource.data.organizationId;
    }

    match /event_rsvps/{rsvpId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || isEventManager(resource.data.organizationId)
        );
      allow create, update: if isSignedIn()
        && (
          request.resource.data.userId == request.auth.uid
          || isEventManager(request.resource.data.organizationId)
        );
    }

    match /event_ticket_orders/{orderId} {
      // Web guest orders are read through the server-side getPublicTicket endpoint
      // (the random orderId is the buyer's capability), not by direct client reads.
      allow read: if isSignedIn() && (
          request.auth.uid == resource.data.buyerId
          || isEventManager(resource.data.organizationId)
        );
      allow create: if validBuyerTicketOrderCreate();
      // Buyers may mark their own order failed; event managers may update their own
      // org's orders (e.g. gate admission / cash collection) but may never set the
      // server-only `settlementEligible` flag or reassign ownership. The Hubtel
      // confirmation that sets `settlementEligible` is server-only (admin SDK).
      allow update: if (
          validBuyerPaymentFailureUpdate()
          || (
            isEventManager(resource.data.organizationId)
            && request.resource.data.organizationId == resource.data.organizationId
          )
        )
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['settlementEligible']);
    }

    match /event_ticket_lookups/{lookupId} {
      allow read: if isEventManager(resource.data.organizationId);
      // Only an event's own managers may create/admit its ticket lookups, and the
      // owning org cannot be reassigned. (Lookups never feed payout balances.)
      allow create: if isEventManager(request.resource.data.organizationId);
      allow update: if isEventManager(resource.data.organizationId)
        && request.resource.data.organizationId == resource.data.organizationId;
    }

    match /event_reminders/{reminderId} {
      allow read, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create, update: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
    }

    match /event_reports/{reportId} {
      allow create: if request.resource.data.keys().hasAll(['eventId', 'eventTitle', 'reason', 'details', 'createdAt'])
        && request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && request.resource.data.eventTitle is string
        && request.resource.data.eventTitle.size() > 0
        && request.resource.data.eventTitle.size() <= 500
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 3
        && request.resource.data.reason.size() <= 500
        && request.resource.data.details is string
        && request.resource.data.details.size() >= 10
        && request.resource.data.details.size() <= 4000
        // Prevent clients from writing arbitrary extra fields
        && request.resource.data.keys().hasOnly(['eventId', 'eventTitle', 'reason', 'details', 'createdAt']);
      allow read: if isAdmin();
      // Admins (Trust & Safety moderation queue) may set review/status fields only.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'reviewedBy', 'reviewedByEmail', 'reviewedAt', 'reviewNotes', 'updatedAt'
        ])
        && request.resource.data.status in ['open', 'reviewing', 'resolved', 'dismissed'];
    }

    // App Store Guideline 1.2 — UGC moderation reports (posts/comments/reviews/
    // profiles). Written ONLY via the reportContent callable (Admin SDK bypasses
    // rules); clients can never create/read/write these directly. Admins read
    // and may advance the moderation status from their console.
    match /content_reports/{reportId} {
      allow create, write: if false;
      allow read: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'reviewedBy', 'reviewedByEmail', 'reviewedAt', 'reviewNotes', 'updatedAt'
        ])
        && request.resource.data.status in ['pending', 'reviewing', 'resolved', 'dismissed'];
    }

    // App Store Guideline 1.2 — per-user block list. The block list is mutated
    // server-side via the blockUser/unblockUser callables, but each user may
    // READ their own list so the client can filter out blocked authors locally.
    match /user_blocks/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Writes go through the callables (Admin SDK). Block direct client writes.
      allow write: if false;
    }

    match /support_tickets/{ticketId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if validSupportTicketCreate();
      allow update: if isAdmin() || validOwnSupportTicketUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAdmin() || ownsSupportTicket(ticketId);
        allow create: if validUserSupportMessageCreate(ticketId)
          || validAdminSupportMessageCreate();
        allow update, delete: if false;
      }
    }

    match /admin_notifications/{notificationId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /event_saves/{userId}/saved/{eventId} {
      allow read, create, update, delete: if isSignedIn()
        && request.auth.uid == userId;
    }

    match /event_reactions/{eventId}/reactions/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventId == eventId;
      allow delete: if isSignedIn()
        && request.auth.uid == userId;
    }

    match /event_reviews/{eventId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventId == eventId;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /creator_profiles/{creatorId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.auth.uid == creatorId
        && request.resource.data.creatorId == request.auth.uid;
      allow delete: if isSignedIn()
        && (request.auth.uid == creatorId || isAdmin());
    }

    match /creator_event_photos/{photoId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /creator_follows/{followId} {
      allow read: if isSignedIn()
        && (
          resource.data.followerId == request.auth.uid
          || resource.data.creatorId == request.auth.uid
          || isAdmin()
        );
      allow create, update: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn()
        && (resource.data.followerId == request.auth.uid || isAdmin());
    }

    match /event_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || (
            // Non-owners may only nudge the denormalised counters by ±1 each —
            // prevents arbitrary like/comment-count forgery.
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'commentCount'])
            && request.resource.data.likeCount is int
            && request.resource.data.commentCount is int
            && request.resource.data.likeCount >= 0
            && request.resource.data.commentCount >= 0
            && request.resource.data.likeCount >= resource.data.likeCount - 1
            && request.resource.data.likeCount <= resource.data.likeCount + 1
            && request.resource.data.commentCount >= resource.data.commentCount - 1
            && request.resource.data.commentCount <= resource.data.commentCount + 1
          )
        );
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /gplus_events/{eventId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /gplus_profiles/{profileId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /gplus_media_gallery/{mediaId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /gplus_sync_status/{syncId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /gelo_content_queue/{itemId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /gelo_event_launch_drafts/{draftId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /gelo_website_features/{featureId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /post_likes/{postId}/likes/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && request.auth.uid == userId;
    }

    match /post_comments/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.postId == postId;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /social_follows/{followerId}/following/{followingId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == followerId
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followingId == followingId;
      allow delete: if isSignedIn()
        && request.auth.uid == followerId;
    }

    match /payout_requests/{requestId} {
      allow read: if isAdmin()
        || (
          isSignedIn()
          && resource.data.organizationId is string
          && isEventManager(resource.data.organizationId)
        );
      allow create, update, delete: if false;
    }

    match /share_links/{shareLinkId} {
      allow read: if resource.data.status == 'active'
        || isEventManager(resource.data.organizationId);
      allow create: if isEventManager(request.resource.data.organizationId);
      allow update: if isEventManager(resource.data.organizationId)
        && request.resource.data.organizationId == resource.data.organizationId;
    }

    match /promotion_campaigns/{campaignId} {
      allow read: if isEventManager(resource.data.organizationId)
        || (
          resource.data.status == 'live'
          && resource.data.channels is list
          && resource.data.channels.hasAny(['featured', 'announcement'])
        );
      allow create: if isEventManager(request.resource.data.organizationId);
      allow update: if isEventManager(resource.data.organizationId)
        && request.resource.data.organizationId == resource.data.organizationId;
    }

    match /places/{placeId} {
      allow read: if resource.data.status == 'active'
        || isEventManager(resource.data.organizationId);
      // All writes go through callables (claimOrCreatePlace, upsertPlaceProfile,
      // confirmPlaceVerification, reviewPlaceVerification) running on the Admin SDK,
      // which keep googlePlaceId / ownerId / verified / featured / verificationStatus
      // server-controlled. No client SDK write path exists — this prevents a manager
      // from self-setting verified/featured to bypass admin review or the paid-push
      // and featured-placement entitlement gates.
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    // Server-only store for place-verification OTP secrets (hashed code + TTL +
    // attempts). Written/read exclusively by the Admin SDK in the verification
    // callables; never exposed to clients.
    match /place_verification_otps/{otpId} {
      allow read, write: if false;
    }

    match /place_menu_sections/{sectionId} {
      allow read: if resource.data.visible != false
        || (
          resource.data.placeId is string
          && exists(/databases/$(database)/documents/places/$(resource.data.placeId))
          && isEventManager(get(/databases/$(database)/documents/places/$(resource.data.placeId)).data.organizationId)
        );
      allow create, update, delete: if false;
    }

    match /place_menu_items/{itemId} {
      allow read: if resource.data.status != 'hidden'
        || (
          resource.data.placeId is string
          && exists(/databases/$(database)/documents/places/$(resource.data.placeId))
          && isEventManager(get(/databases/$(database)/documents/places/$(resource.data.placeId)).data.organizationId)
        );
      allow create, update, delete: if false;
    }

    match /place_reservations/{reservationId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || isEventManager(resource.data.organizationId)
        );
      allow create, update, delete: if false;
    }

    match /place_subscriptions/{subscriptionId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || (
            resource.data.placeId is string
            && exists(/databases/$(database)/documents/places/$(resource.data.placeId))
            && isEventManager(get(/databases/$(database)/documents/places/$(resource.data.placeId)).data.organizationId)
          )
        );
      allow create, update: if validPlaceSubscription(subscriptionId);
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.userId;
    }

    match /place_verifications/{requestId} {
      allow read: if isSignedIn()
        && (
          resource.data.requestedBy == request.auth.uid
          || isAdmin()
          || (
            resource.data.organizationId is string
            && isEventManager(resource.data.organizationId)
          )
        );
      allow create, update, delete: if false;
    }

    match /audience_contacts/{contactId} {
      allow read: if isEventManager(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /event_ops_configs/{configId} {
      allow read: if isAdmin() || isEventManager(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /event_inventory_items/{itemId} {
      allow read: if isAdmin() || isEventManager(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /event_ops_staff/{staffId} {
      allow read: if isAdmin() || isEventManager(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /event_ops_staff_sessions/{sessionId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /event_ops_tabs/{tabId} {
      allow read: if isAdmin() || isEventManager(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /event_ops_reports/{reportId} {
      allow read: if isAdmin() || isEventManager(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /event_ops_onboarding_visuals/{visualId} {
      allow read: if isAdmin() || isEventManager(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /event_ops_access_codes/{codeId} {
      allow read, write: if false;
    }

    match /production_monitor_alerts/{alertId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /creative_brand_configs/{organizationId} {
      allow read: if isEventManager(organizationId);
      allow create, update, delete: if false;
    }

    match /flyer_jobs/{jobId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.uid
          || isEventManager(resource.data.organizationId)
        );
      allow create, update, delete: if false;
    }

    match /flyer_video_jobs/{jobId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.uid
          || isEventManager(resource.data.organizationId)
        );
      allow create, update, delete: if false;
    }

    match /flyer_sessions/{sessionId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.uid
          || isEventManager(resource.data.organizationId)
        );
      allow create, update, delete: if false;
    }

    match /notification_jobs/{jobId} {
      allow read: if isAdmin();
    }

    match /push_queue/{queueId} {
      allow read: if isAdmin();
    }

    match /advertiser_wallets/{walletId} {
      allow read: if isEventManager(walletId);
      allow create, update, delete: if false;
    }

    match /wallet_transactions/{transactionId} {
      allow read: if isSignedIn()
        && resource.data.walletId is string
        && isEventManager(resource.data.walletId);
      allow create, update, delete: if false;
    }

    match /sms_opt_out/{phone} {
      allow read, write: if false;
    }

    match /promo_packages/{packageId} {
      allow read, write: if false;
    }
  }
}
