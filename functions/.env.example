# =============================================================================
# Vennuzo Cloud Functions — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these as Firebase Function secrets:
#   firebase functions:secrets:set HUBTEL_SMS_CLIENT_ID
#
# .env.local is gitignored — NEVER commit real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Hubtel SMS (required for campaign SMS delivery)
# Obtain from: https://developers.hubtel.com
# -----------------------------------------------------------------------------
HUBTEL_SMS_CLIENT_ID=your_hubtel_sms_client_id
HUBTEL_SMS_CLIENT_SECRET=your_hubtel_sms_client_secret
HUBTEL_SMS_SENDER_ID=Vennuzo

# -----------------------------------------------------------------------------
# Hubtel Payment Checkout (required for ticket purchases and wallet top-ups)
# Obtain from: https://developers.hubtel.com → Merchant settings
# -----------------------------------------------------------------------------
HUBTEL_MERCHANT_ACCOUNT_NUMBER=your_merchant_account_number
HUBTEL_API_CLIENT_ID=your_hubtel_api_client_id
HUBTEL_API_CLIENT_SECRET=your_hubtel_api_client_secret
# Optional: enables Hubtel callback signature verification (HMAC-SHA256 over the
# raw callback body via the x-hubtel-signature header). Leave EMPTY to run
# fail-open (no verification). When set, use the SAME value in the Hubtel
# merchant dashboard. Also readable from app_config/hubtel.callbackSecret.
HUBTEL_CALLBACK_SECRET=

# -----------------------------------------------------------------------------
# Google Places API (required for venue search + place claiming)
# Set as a Firebase secret:  firebase functions:secrets:set GOOGLE_PLACES_API_KEY
# Enable "Places API (New)" + "Geocoding API" in Google Cloud for this key.
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# -----------------------------------------------------------------------------
# Gemini API (required for AI flyer / event-detail / onboarding-visual generation)
# Set as a Firebase secret:  firebase functions:secrets:set GEMINI_API_KEY
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# -----------------------------------------------------------------------------
# App URLs (used to build payment redirect links)
# -----------------------------------------------------------------------------
# Base URL of the deployed Studio web app (no trailing slash)
VENNUZO_STUDIO_URL=https://your-project.web.app

# Base URL of the public Vennuzo site used in ticket SMS/email links
VENNUZO_PUBLIC_URL=https://vennuzo.web.app

# -----------------------------------------------------------------------------
# Ticket Email Delivery (required for purchased-ticket email confirmations)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_app_password
FROM_EMAIL=tickets@vennuzo.app
FROM_NAME=Vennuzo

# -----------------------------------------------------------------------------
# Optional — Debug / development flags
# Set to "true" to enable DEBUG-level structured log output
# -----------------------------------------------------------------------------
FUNCTIONS_DEBUG=false
