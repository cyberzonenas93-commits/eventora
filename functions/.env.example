# =============================================================================
# Vennuzo Cloud Functions — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production, set these as Firebase Function secrets:
#   firebase functions:secrets:set HUBTEL_SMS_CLIENT_ID
#
# .env.local is gitignored — NEVER commit real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Hubtel SMS (required for campaign SMS delivery)
# Obtain from: https://developers.hubtel.com
# -----------------------------------------------------------------------------
HUBTEL_SMS_CLIENT_ID=your_hubtel_sms_client_id
HUBTEL_SMS_CLIENT_SECRET=your_hubtel_sms_client_secret
HUBTEL_SMS_SENDER_ID=Vennuzo

# -----------------------------------------------------------------------------
# Hubtel Payment Checkout (required for ticket purchases and wallet top-ups)
# Obtain from: https://developers.hubtel.com → Merchant settings
# -----------------------------------------------------------------------------
HUBTEL_MERCHANT_ACCOUNT_NUMBER=your_merchant_account_number
HUBTEL_API_CLIENT_ID=your_hubtel_api_client_id
HUBTEL_API_CLIENT_SECRET=your_hubtel_api_client_secret

# -----------------------------------------------------------------------------
# App URLs (used to build payment redirect links)
# -----------------------------------------------------------------------------
# Base URL of the deployed Studio web app (no trailing slash)
VENNUZO_STUDIO_URL=https://your-project.web.app

# -----------------------------------------------------------------------------
# Optional — Debug / development flags
# Set to "true" to enable DEBUG-level structured log output
# -----------------------------------------------------------------------------
FUNCTIONS_DEBUG=false
