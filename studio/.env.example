# =============================================================================
# Vennuzo Studio — Environment Variables
# =============================================================================
# Copy to .env.local for local development (gitignored).
# For production set these in Firebase Hosting environment config or CI.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# =============================================================================

# Firebase project config (client-side — safe to be public)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=vennuzo.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Sign in with Apple requires Firebase Auth provider config, not browser env vars.
# Firebase Apple provider should be configured with:
# - Services ID/client ID: Vennuzo's Apple web Services ID, e.g. com.vennuzo.web
# - Team ID: 36TZ8UKL8W
# - Key ID/private key: Sign in with Apple key for the Vennuzo Services ID
# - Bundle ID: com.vennuzo.app

# Optional local Firebase emulator wiring
VITE_USE_FIREBASE_EMULATORS=false
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_AUTH_EMULATOR_PORT=9099
VITE_FIREBASE_FIRESTORE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_FIRESTORE_EMULATOR_PORT=8080
VITE_FIREBASE_FUNCTIONS_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_FUNCTIONS_EMULATOR_PORT=5001

# Sentry DSN — optional; error reporting is disabled when unset
# Obtain from: https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=

# Build version shown in Sentry releases (e.g. git SHA or semver)
VITE_APP_VERSION=
