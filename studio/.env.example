# =============================================================================
# Vennuzo Studio — Environment Variables
# =============================================================================
# Copy to .env.local for local development (gitignored).
# For production set these in Firebase Hosting environment config or CI.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# =============================================================================

# Firebase project config (client-side — safe to be public)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Sentry DSN — optional; error reporting is disabled when unset
# Obtain from: https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=

# Build version shown in Sentry releases (e.g. git SHA or semver)
VITE_APP_VERSION=
